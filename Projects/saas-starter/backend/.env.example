# Django Settings
# REQUIRED: Set a strong SECRET_KEY in production (use Django secret key generator)
# Generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here-change-in-production

# REQUIRED in production: DEBUG must be False to enable security headers
DEBUG=False

# REQUIRED in production: Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com,www.yourdomain.com

# Database (optional, defaults to SQLite for development)
# For PostgreSQL: DATABASE_URL=postgresql://user:password@host:5432/dbname
# For production, use PostgreSQL or another robust database
# DATABASE_URL=

# Stripe API Keys (get from https://dashboard.stripe.com/apikeys)
# CRITICAL: Use LIVE keys in production, TEST keys in development
STRIPE_PUBLIC_KEY=pk_live_your_public_key_here
STRIPE_SECRET_KEY=sk_live_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_ID=price_your_price_id_here

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# CORS Configuration
# REQUIRED: Set CORS_ALLOWED_ORIGINS to your frontend domain
# Comma-separated list (no trailing slashes)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# CSRF Trusted Origins
# REQUIRED: Set to your frontend domain(s)
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# AUTHENTICATION & JWT
# ============================================================================

# JWT tokens are configured in settings.py
# Access tokens expire in 15 minutes
# Refresh tokens expire in 7 days
# All tokens use your SECRET_KEY for signing

# ============================================================================
# REDIS CACHING (REQUIRED FOR PRODUCTION RATE LIMITING)
# ============================================================================

# For production, set up Redis for rate limiting and caching
# Format: redis://username:password@localhost:6379/0
# If not set, rate limiting will use local memory cache (single-process only)
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# EMAIL CONFIGURATION (REQUIRED FOR NOTIFICATIONS)
# ============================================================================

# SMTP Configuration for transactional emails
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Default sender email address
DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ============================================================================
# OPTIONAL: SENTRY ERROR TRACKING
# ============================================================================

# For production, use Sentry for error tracking and monitoring
# Get from https://sentry.io
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ============================================================================
# OPTIONAL: AWS S3 FOR FILE STORAGE
# ============================================================================

# If using AWS S3 for file uploads/storage, configure these
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# OPTIONAL: OPENAI API FOR AI FEATURES
# ============================================================================

# OPENAI_API_KEY=sk_your_openai_api_key_here

# ============================================================================
# LOGGING LEVEL (OPTIONAL)
# ============================================================================

# Django logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Set to INFO in production
DJANGO_LOG_LEVEL=INFO
